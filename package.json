{
  "name": "simple-strapi",
  "version": "1.0.0-alpha.27",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hund-studio/simple-strapi.git"
  },
  "bugs": {
    "url": "https://github.com/hund-studio/simple-strapi/issues"
  },
  "homepage": "https://github.com/hund-studio/simple-strapi#readme",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "copy:readme": "cp docs/readme.md ./README.md",
    "postpublish": "rm ./README.md",
    "prepublishOnly": "npm run build && npm run copy:readme",
    "release:alpha": "npm version prerelease --preid alpha && git push --follow-tags",
    "release:beta": "npm version prerelease --preid beta && git push --follow-tags",
    "release:minor": "npm version minor && git push --follow-tags",
    "release:patch": "npm version patch && git push --follow-tags",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "node-fetch": "^3.3.2",
    "qs": "^6.14.0",
    "simple-exception": "github:hund-studio/simple-exception",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@types/node": "^24.0.14",
    "@types/qs": "^6.14.0",
    "tsx": "^4.20.3",
    "typescript": "^5.0.0"
  }
}
